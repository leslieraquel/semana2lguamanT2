<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="semana2lguamanT2.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
        
            <Picker x:Name="pkCompaneros" Title="Seleccione compañero">
                <Picker.Items>
                    <x:String>David Mera</x:String>
                    <x:String>Jefferson suntaxi</x:String>
                    <x:String>Michael cardenas</x:String>
                    <x:String>Daysi Diaz</x:String>
                    <x:String>Raquel Guaman</x:String>
                </Picker.Items>
            </Picker>

            <Entry x:Name="txtSeguimiento1" Keyboard="Numeric" Placeholder="Seguimiento 1"/>
            <Entry x:Name="txtExamen1" Keyboard="Numeric" Placeholder="Examen 1"/>

            <Entry x:Name="txtSeguimiento2" Keyboard="Numeric" Placeholder="Seguimiento 2"/>
            <Entry x:Name="txtExamen2" Keyboard="Numeric" Placeholder="Examen 2"/>

            <DatePicker x:Name="dpFecha"/>

            <Button Text="Calcular"
            Clicked="Button_Clicked"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
